# ─────────────────────────────────────────────────────────
#  .env.example  —  copy to .env and fill in values
#  NagaraVaani backend (pgvector edition)
# ─────────────────────────────────────────────────────────

# ── PostgreSQL (Supabase with pgvector) ────────────────
DATABASE_URL=postgresql://postgres:yourpassword@db.host.supabase.co:5432/postgres

# ── Local Ollama AI Server ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Supabase (still used for departments if you haven't
#    migrated them yet — optional once you're fully on PG)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# ── Twilio / WhatsApp bot (optional) ─────────────────────
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx

# ── Server ────────────────────────────────────────────────
PORT=3000
VITE_API_URL=https://your-ngrok-url.ngrok-free.app
